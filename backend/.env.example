# ──────────────────────────────────────────────
# RotaZAP — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# ──────────────────────────────────────────────

# Banco de Dados (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/rotazap"

# Autenticação JWT (obrigatório — mínimo 32 caracteres aleatórios)
JWT_SECRET="gere_uma_chave_aleatoria_longa_aqui_minimo_32_chars"

# Mercado Pago (obrigatório para pagamentos)
# Obtenha em: https://www.mercadopago.com.br/developers/panel/credentials
MP_ACCESS_TOKEN="APP_USR-seu-access-token-aqui"
MP_PUBLIC_KEY="APP_USR-sua-public-key-aqui"

# URL da aplicação no servidor (usada nos callbacks de pagamento)
APP_URL="http://72.60.250.170:3002/rotazap"

# Webhook (URL que o Mercado Pago chama após pagamento aprovado)
WEBHOOK_URL="http://72.60.250.170:3002/rotazap/api/webhook"

# Porta do servidor
PORT=3002

# Email (para recuperação de senha — opcional)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="seu-email@gmail.com"
SMTP_PASS="sua-senha-de-app-google"
