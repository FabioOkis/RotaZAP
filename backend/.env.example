# Database
DATABASE_URL="postgresql://user:password@localhost:5432/rotazap"

# JWT
JWT_SECRET="sua_chave_secreta_super_segura_aqui_minimo_32_caracteres"
JWT_EXPIRE="7d"

# Mercado Pago
MERCADOPAGO_ACCESS_TOKEN="seu_access_token_mp"
MERCADOPAGO_PUBLIC_KEY="sua_public_key_mp"
MERCADOPAGO_NOTIFICATION_URL="https://seu-dominio.com/api/payments/webhook"

# Server
PORT=3000
NODE_ENV="development"

# CORS
CORS_ORIGIN="http://localhost:3000,https://seu-dominio.com"

# Email (para notificações)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="seu-email@gmail.com"
SMTP_PASS="sua-senha-app"

# API Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
